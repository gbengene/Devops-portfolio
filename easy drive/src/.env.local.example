# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                    # from Stripe dashboard webhooks

# ── Bouncie (GPS) ─────────────────────────────────────────────────────────────
BOUNCIE_API_KEY=your-bouncie-api-key
BOUNCIE_WEBHOOK_SECRET=your-bouncie-webhook-secret

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX                    # your Twilio Ontario number
ADMIN_PHONE_NUMBER=+1XXXXXXXXXX                    # your mobile for alerts

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@easydrive.ca
ADMIN_EMAIL=owner@easydrive.ca

# ── PandaDoc (E-signature) ────────────────────────────────────────────────────
PANDADOC_API_KEY=your-pandadoc-api-key
PANDADOC_TEMPLATE_ID=your-rental-agreement-template-id

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://easydrive.ca
